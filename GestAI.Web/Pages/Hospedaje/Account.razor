@page "/account"
@inject ApiClient Api
@using GestAI.Web.Dtos

<section class="page-hero">
    <div>
        <div class="page-hero-title">Mi cuenta</div>
        <div class="page-hero-subtitle">Actualizá la información general del tenant y revisá el estado actual de tu cuenta.</div>
    </div>
    <div class="page-hero-meta">
        <span class="page-hero-chip"><i class="bi bi-building"></i> Perfil del tenant</span>
    </div>
</section>

@if (_summary is null)
{
    <div class="card"><div class="card-body">Cargando datos de cuenta...</div></div>
}
else
{
    <div class="ui-split-layout">
        <div class="card">
            <div class="card-body">
                <div class="ui-card-header">
                    <div>
                        <h5 class="ui-card-title">Información general</h5>
                        <div class="ui-card-subtitle">Resumen operativo y estado actual del tenant.</div>
                    </div>
                </div>
                <div class="ui-list-stack">
                    <div class="ui-check-card"><i class="bi bi-activity text-primary"></i><div><strong>Estado</strong><div class="ui-table-meta">@(_summary.IsActive ? "Activo" : "Inactivo")</div></div></div>
                    <div class="ui-check-card"><i class="bi bi-calendar-event text-primary"></i><div><strong>Creación</strong><div class="ui-table-meta">@_summary.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div></div></div>
                    <div class="ui-check-card"><i class="bi bi-stars text-primary"></i><div><strong>Plan</strong><div class="ui-table-meta">@_summary.PlanName</div></div></div>
                    <div class="ui-check-card"><i class="bi bi-people text-primary"></i><div><strong>Límites</strong><div class="ui-table-meta">Usuarios @_summary.MaxUsers · Entidades @_summary.MaxUnits</div></div></div>
                </div>
            </div>
        </div>

        <div class="card ui-form-card">
            <div class="card-body">
                <div class="ui-card-header">
                    <div>
                        <h5 class="ui-card-title">Editar nombre de cuenta</h5>
                        <div class="ui-card-subtitle">Usá un nombre claro para identificar el tenant.</div>
                    </div>
                </div>
                <label class="form-label">Nombre de cuenta</label>
                <input class="form-control" @bind="_name" />
                <div class="ui-action-bar">
                    <button class="btn btn-primary" @onclick="Save">Guardar cambios</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private AccountSummaryDto? _summary;
    private string _name = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _summary = (await Api.GetAsync<AppResult<AccountSummaryDto>>("api/saas/account/summary"))?.Data;
        _name = _summary?.Name ?? string.Empty;
    }

    private async Task Save()
    {
        await Api.PutAsync("api/saas/account", new UpdateAccountCommand(_name, null));
        _summary = (await Api.GetAsync<AppResult<AccountSummaryDto>>("api/saas/account/summary"))?.Data;
    }
}
