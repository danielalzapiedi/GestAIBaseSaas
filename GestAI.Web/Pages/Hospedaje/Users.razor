@page "/users"
@using GestAI.Web.Dtos
@inject ApiClient Api

<h1>Usuarios</h1>
<p class="text-muted">Gestión básica de usuarios del tenant.</p>

<button class="btn btn-primary mb-3" @onclick="NewUser">Nuevo usuario</button>

@if (!_loaded)
{
    <p>Cargando...</p>
}
else
{
    <table class="table table-striped">
        <thead><tr><th>Nombre</th><th>Email</th><th>Rol</th><th>Módulos</th><th>Activo</th><th></th></tr></thead>
        <tbody>
        @foreach (var u in _items)
        {
            <tr>
                <td>@u.DisplayName</td><td>@u.Email</td><td>@u.Role</td><td>@FormatModules(u)</td><td>@(u.IsActive ? "Sí" : "No")</td>
                <td>
                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Edit(u)">Editar</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => Toggle(u)">@(u.IsActive ? "Desactivar" : "Activar")</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@if (_showForm)
{
    <div class="card"><div class="card-body">
        <div class="row g-2">
            <div class="col"><input class="form-control" placeholder="Nombre" @bind="_form.Nombre" /></div>
            <div class="col"><input class="form-control" placeholder="Apellido" @bind="_form.Apellido" /></div>
            <div class="col"><input class="form-control" placeholder="Email" @bind="_form.Email" /></div>
        </div>
        <div class="row g-2 mt-2">
            <div class="col">
                <select class="form-select" value="@_form.Role" @onchange="OnRoleChanged">
                    @foreach (var role in Enum.GetValues<InternalUserRole>())
                    {
                        <option value="@role">@role</option>
                    }
                </select>
            </div>
            <div class="col"><input class="form-control" placeholder="Password temporal" @bind="_form.Password" disabled="@(_form.UserId is not null)" /></div>
        </div>
        <div class="mt-3">
            <label class="form-label">Permisos por módulo</label>
            @if (_form.Role == InternalUserRole.Owner)
            {
                <div class="alert alert-info py-2 mb-0">
                    El rol Owner tiene acceso completo a los módulos del tenant.
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 g-2">
                    @foreach (var module in _tenantModules)
                    {
                        <div class="col">
                            <label class="form-check">
                                <input class="form-check-input" type="checkbox" checked="@_form.AllowedModules.Contains(module)" @onchange="e => ToggleModule(module, e.Value)" />
                                <span class="form-check-label">@GetModuleLabel(module)</span>
                            </label>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="mt-3">
            <button class="btn btn-primary me-1" @onclick="Save">Guardar</button>
            <button class="btn btn-outline-secondary" @onclick="() => _showForm=false">Cancelar</button>
        </div>
    </div></div>
}

@code {
    private bool _loaded;
    private bool _showForm;
    private List<AccountUserListItemDto> _items = new();
    private UpsertAccountUserCommand _form = new();
    private static readonly List<SaasModule> _tenantModules = Enum.GetValues<SaasModule>().Where(x => x != SaasModule.PlatformTenants).ToList();
    private static readonly List<SaasModule> _defaultEmployeeModules = new()
    {
        SaasModule.Dashboard,
        SaasModule.Branches,
        SaasModule.Warehouses,
        SaasModule.Categories,
        SaasModule.Products,
        SaasModule.Customers,
        SaasModule.Suppliers
    };

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _items = (await Api.GetAsync<AppResult<List<AccountUserListItemDto>>>("api/saas/users"))?.Data ?? new();
        _loaded = true;
    }

    private void NewUser()
    {
        _form = new UpsertAccountUserCommand
        {
            IsActive = true,
            Role = InternalUserRole.Employee,
            AllowedModules = _defaultEmployeeModules.ToList(),
            Password = "Temp123$"
        };
        _showForm = true;
    }

    private void Edit(AccountUserListItemDto u)
    {
        var parts = (u.DisplayName ?? string.Empty).Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);
        _form = new UpsertAccountUserCommand
        {
            UserId = u.UserId,
            Nombre = parts.Length > 0 ? parts[0] : string.Empty,
            Apellido = parts.Length > 1 ? parts[1] : string.Empty,
            Email = u.Email,
            IsActive = u.IsActive,
            Role = u.Role,
            AllowedModules = u.AllowedModules.ToList()
        };
        _showForm = true;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_form.UserId)) await Api.PostAsync("api/saas/users", _form);
        else await Api.PutAsync($"api/saas/users/{_form.UserId}", _form);
        _showForm = false;
        await Load();
    }

    private async Task Toggle(AccountUserListItemDto u)
    {
        await Api.PostAsync($"api/saas/users/{u.UserId}/status", new { isActive = !u.IsActive });
        await Load();
    }

    private void OnRoleChanged(ChangeEventArgs args)
    {
        if (!Enum.TryParse<InternalUserRole>(args.Value?.ToString(), out var role))
            return;

        _form.Role = role;
        _form.AllowedModules = role == InternalUserRole.Owner
            ? _tenantModules.ToList()
            : (_form.AllowedModules.Count > 0 ? _form.AllowedModules.Where(x => x != SaasModule.PlatformTenants).Distinct().ToList() : _defaultEmployeeModules.ToList());
    }

    private void ToggleModule(SaasModule module, object? value)
    {
        var isChecked = value is bool flag ? flag : bool.TryParse(value?.ToString(), out var parsed) && parsed;
        if (isChecked == true)
        {
            if (!_form.AllowedModules.Contains(module))
                _form.AllowedModules.Add(module);
        }
        else
        {
            _form.AllowedModules.Remove(module);
        }
    }

    private static string GetModuleLabel(SaasModule module) => module switch
    {
        SaasModule.Dashboard => "Dashboard",
        SaasModule.Users => "Usuarios",
        SaasModule.Configuration => "Configuración",
        SaasModule.AuditLog => "Auditoría",
        SaasModule.Plans => "Plan",
        SaasModule.Branches => "Sucursales",
        SaasModule.Warehouses => "Depósitos",
        SaasModule.Categories => "Categorías",
        SaasModule.Products => "Productos",
        SaasModule.Customers => "Clientes",
        SaasModule.Suppliers => "Proveedores",
        _ => module.ToString()
    };

    private static string FormatModules(AccountUserListItemDto user)
        => user.Role == InternalUserRole.Owner
            ? "Acceso completo"
            : string.Join(", ", user.AllowedModules.Select(GetModuleLabel));
}
