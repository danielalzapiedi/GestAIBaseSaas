@if (UseResponsiveContainer)
{
    <div class="@ResponsiveContainerClass">
        <table class="@ResolvedTableClass">
            @ChildContent
        </table>
    </div>
}
else
{
    <table class="@ResolvedTableClass">
        @ChildContent
    </table>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string TableClass { get; set; } = "table ui-modern-grid";
    [Parameter] public bool UseResponsiveContainer { get; set; } = true;
    [Parameter] public bool ActionsDropdown { get; set; }

    private string ResolvedTableClass => string.IsNullOrWhiteSpace(TableClass) ? "table ui-modern-grid" : TableClass;
    private string ResponsiveContainerClass => ActionsDropdown
        ? "table-responsive ui-table-responsive-actions"
        : "table-responsive";
}
